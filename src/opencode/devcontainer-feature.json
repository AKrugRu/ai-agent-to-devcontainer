{
    "name": "Add opencode to devcontainer",
    "id": "opencode",
    "version": "1.0.0",
    "description": "Добавляем в devcontainer агента opencode последней версии",
    "options": {
        "version": {
            "type": "string",
            "proposals": ["1.18.1", "latest"],
            "default": "latest",
            "description": "Укажите версию для установки"
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/node"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "sst-dev.opencode"
            ]
        }
    }
}
